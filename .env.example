# =============================================================================
# Univer Tracker — Environment Variables
# =============================================================================

# --- App ---
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080
PUBLIC_URL=http://localhost:3000

# --- Database ---
DATABASE_URL=postgres://univertracker:univertracker@localhost:5432/univertracker?sslmode=disable

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Auth ---
JWT_SECRET=change-me-in-production-please-use-a-real-secret
JWT_EXPIRES_IN=7d

# --- WooCommerce ---
WC_URL=https://lizzon.com.br
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=

# --- Frenet ---
FRENET_API_TOKEN=
FRENET_PANEL_EMAIL=
FRENET_PANEL_PASSWORD=

# --- ZapGrup ---
ZAPGRUP_URL=https://zapgrup.cloud
ZAPGRUP_API_TOKEN=

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=Univer Tracker
