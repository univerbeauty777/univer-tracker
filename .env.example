# =============================================================================
# Univer Tracker — environment variables
# =============================================================================
# In production (Coolify), the SERVICE_FQDN_BACKEND_8080 and
# SERVICE_FQDN_FRONTEND_3000 vars are set automatically when the domain
# is configured in the Coolify UI. APP_URL / PUBLIC_URL / NEXT_PUBLIC_API_URL
# are then derived from SERVICE_URL_* in docker-compose.yml — no manual
# setting needed there.
#
# This file documents what's required for local development with
# `docker compose up -d` and matches the keys read by the application.
# =============================================================================

# --- Postgres ---
POSTGRES_USER=univertracker
POSTGRES_PASSWORD=univertracker
POSTGRES_DB=univertracker

# --- App ---
APP_ENV=development

# --- Auth ---
# In production: openssl rand -base64 64
JWT_SECRET=change-me-in-production-please-use-a-real-secret-of-at-least-32-chars
JWT_EXPIRES_IN=7d

# --- WooCommerce ---
WC_URL=https://lizzon.com.br
WC_CONSUMER_KEY=
WC_CONSUMER_SECRET=
WC_WEBHOOK_SECRET=

# --- Frenet ---
FRENET_API_TOKEN=
FRENET_PANEL_EMAIL=
FRENET_PANEL_PASSWORD=

# --- ZapGrup ---
ZAPGRUP_URL=https://zapgrup.cloud
ZAPGRUP_API_TOKEN=

# =============================================================================
# Coolify-managed (do not set manually in production)
# =============================================================================
# SERVICE_FQDN_BACKEND_8080   → set by Coolify when you configure the API domain
# SERVICE_FQDN_FRONTEND_3000  → set by Coolify when you configure the frontend domain
# SERVICE_URL_BACKEND_8080    → derived URL (https://...)
# SERVICE_URL_FRONTEND_3000   → derived URL (https://...)
